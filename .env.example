# ── Recall Environment Configuration ──

# Database
DATABASE_URL=postgresql+asyncpg://recall:recall@localhost:5432/recall
DATABASE_URL_SYNC=postgresql://recall:recall@localhost:5432/recall

# Redis (used for multi-replica rate limiting when APP_ENV is not ``test``)
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMITING=true

# Weaviate (Vector DB)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# LiteLLM (AI Model Router)
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-recall-dev

# LLM Provider Keys (add as needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Auth (Authentik)
AUTHENTIK_URL=http://localhost:9000
AUTHENTIK_TOKEN=
AUTHENTIK_CLIENT_ID=recall
AUTHENTIK_CLIENT_SECRET=

# Temporal — optional; start with: docker compose --profile extras up -d
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=recall

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Composio (Integration Hub)
COMPOSIO_API_KEY=

# File Storage (S3-compatible) — optional MinIO via compose profile ``extras``
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recall-files
